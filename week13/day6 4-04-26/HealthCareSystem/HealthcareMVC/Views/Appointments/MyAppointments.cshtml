@model List<AppointmentViewModel>
@{
    ViewData["Title"] = "My Appointments";
    Layout = "_Layout";
}

<div class="appointments-container">
    <h1 class="page-title">My Appointments 💌</h1>

    @if (Model == null || Model.Count == 0)
    {
        <div class="no-data">
            <p>You don't have any appointments yet.</p>
            <a href="/doctors" class="btn btn-primary">Browse Doctors</a>
        </div>
    }
    else
    {
        <div class="appointments-list">
            @foreach (var appointment in Model)
            {
                <div class="appointment-item" id="appointment-@appointment.AppointmentId">
                    <div class="appointment-info">
                        <h3>Dr. @appointment.DoctorName</h3>
                        <p class="appointment-date">📅 @appointment.AppointmentDate.ToString("MMMM dd, yyyy hh:mm tt")</p>
                        <span class="status-badge status-@appointment.Status.ToLower()" id="status-@appointment.AppointmentId">
                            @appointment.Status
                        </span>
                    </div>
                    
                    @if (appointment.Status == "Booked")
                    {
                        <form method="post" action="/appointments/cancel" style="display: inline;" 
                              class="cancel-form" data-appointment-id="@appointment.AppointmentId">
                            <input type="hidden" name="appointmentId" value="@appointment.AppointmentId" />
                            <button type="submit" class="btn btn-danger btn-small" id="cancelBtn-@appointment.AppointmentId">Cancel</button>
                        </form>
                    }
                </div>
            }
        </div>

        <script>
            document.querySelectorAll('.cancel-form').forEach(form => {
                form.addEventListener('submit', function(e) {
                    e.preventDefault();
                    const appointmentId = this.getAttribute('data-appointment-id');
                    const cancelBtn = document.getElementById('cancelBtn-' + appointmentId);
                    
                    if (confirm('Are you sure you want to cancel this appointment? This action cannot be undone.')) {
                        cancelBtn.disabled = true;
                        cancelBtn.textContent = 'Cancelling...';
                        this.submit();
                    }
                });
            });

            // Add hover effect to appointment items
            document.querySelectorAll('.appointment-item').forEach(item => {
                item.addEventListener('mouseenter', function() {
                    this.style.backgroundColor = '#f9f9f9';
                });
                item.addEventListener('mouseleave', function() {
                    this.style.backgroundColor = 'white';
                });
            });

            // Status color coding
            document.querySelectorAll('.status-badge').forEach(badge => {
                const status = badge.textContent.trim().toLowerCase();
                if (status === 'booked') {
                    badge.style.borderLeft = '4px solid var(--success)';
                } else if (status === 'completed') {
                    badge.style.borderLeft = '4px solid var(--success)';
                } else if (status === 'cancelled') {
                    badge.style.borderLeft = '4px solid var(--danger)';
                }
            });
        </script>
    }
</div>

<style>
    .appointments-list {
        transition: all 0.3s ease;
    }

    .appointment-item {
        cursor: pointer;
        transition: background-color 0.3s ease;
    }

    #cancelBtn-:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }
</style>
