@{
    ViewData["Title"] = "Register";
}

<div style="max-width: 500px; margin: 2rem auto; padding: 2rem; background: linear-gradient(135deg, #C5A3FF 0%, #A8D8FF 100%); border-radius: 15px; box-shadow: 0 8px 32px rgba(0,0,0,0.1);">
    <h2 style="text-align: center; color: #6B5B7F; font-family: 'Caveat', cursive; font-size: 2rem; margin-bottom: 1.5rem;">✨ Create Your Account ✨</h2>
    
    @if (!string.IsNullOrEmpty(ViewBag.Error))
    {
        <div style="background-color: #FFD4A3; color: #6B5B7F; padding: 1rem; border-radius: 10px; margin-bottom: 1rem; border-left: 4px solid #FF6B6B;">
            @ViewBag.Error
        </div>
    }

    @if (!string.IsNullOrEmpty(ViewBag.Success))
    {
        <div style="background-color: #A8FFD8; color: #6B5B7F; padding: 1rem; border-radius: 10px; margin-bottom: 1rem; border-left: 4px solid #22C55E;">
            @ViewBag.Success
        </div>
    }

    <form method="post" asp-action="Register" asp-controller="Auth">
        <div style="margin-bottom: 1rem;">
            <label for="username" style="display: block; color: #6B5B7F; font-weight: bold; margin-bottom: 0.5rem; font-family: 'Quicksand', sans-serif;">Username</label>
            <input type="text" id="username" name="username" required style="width: 100%; padding: 0.75rem; border: 2px solid #C5A3FF; border-radius: 8px; font-family: 'Quicksand', sans-serif; background-color: rgba(255,255,255,0.9); box-sizing: border-box;" placeholder="Choose a username" />
        </div>

        <div style="margin-bottom: 1rem;">
            <label for="email" style="display: block; color: #6B5B7F; font-weight: bold; margin-bottom: 0.5rem; font-family: 'Quicksand', sans-serif;">Email</label>
            <input type="email" id="email" name="email" required style="width: 100%; padding: 0.75rem; border: 2px solid #C5A3FF; border-radius: 8px; font-family: 'Quicksand', sans-serif; background-color: rgba(255,255,255,0.9); box-sizing: border-box;" placeholder="Enter your email" />
        </div>

        <div style="margin-bottom: 1rem;">
            <label for="fullName" style="display: block; color: #6B5B7F; font-weight: bold; margin-bottom: 0.5rem; font-family: 'Quicksand', sans-serif;">Full Name</label>
            <input type="text" id="fullName" name="fullName" required style="width: 100%; padding: 0.75rem; border: 2px solid #C5A3FF; border-radius: 8px; font-family: 'Quicksand', sans-serif; background-color: rgba(255,255,255,0.9); box-sizing: border-box;" placeholder="Enter your full name" />
        </div>

        <div style="margin-bottom: 1.5rem;">
            <label for="password" style="display: block; color: #6B5B7F; font-weight: bold; margin-bottom: 0.5rem; font-family: 'Quicksand', sans-serif;">Password</label>
            <input type="password" id="password" name="password" required style="width: 100%; padding: 0.75rem; border: 2px solid #C5A3FF; border-radius: 8px; font-family: 'Quicksand', sans-serif; background-color: rgba(255,255,255,0.9); box-sizing: border-box;" placeholder="Enter a strong password" />
        </div>

        <button type="submit" style="width: 100%; padding: 0.75rem; background: linear-gradient(135deg, #FFD4A3 0%, #A8FFD8 100%); color: #6B5B7F; border: none; border-radius: 25px; font-weight: bold; font-family: 'Quicksand', sans-serif; cursor: pointer; transition: transform 0.3s ease, box-shadow 0.3s ease; box-shadow: 0 4px 15px rgba(0,0,0,0.1);">
            Create Account
        </button>
    </form>

    <p style="text-align: center; margin-top: 1.5rem; color: #6B5B7F; font-family: 'Quicksand', sans-serif;">
        Already have an account? 
        <a asp-action="Login" asp-controller="Auth" style="color: #FF6B6B; text-decoration: none; font-weight: bold;">Login here</a>
    </p>

    <p style="text-align: center; margin-top: 1rem;">
        <a asp-action="Index" asp-controller="Home" style="color: #6B5B7F; text-decoration: none; font-family: 'Quicksand', sans-serif;">← Back to Shop</a>
    </p>
</div>
