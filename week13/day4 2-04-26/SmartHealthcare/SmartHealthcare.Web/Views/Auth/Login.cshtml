@model SmartHealthcare.Models.DTOs.LoginDTO

@{
    ViewData["Title"] = "Login";
}

<div class="container-custom">
    <h1 style="text-align: center; margin-bottom: 2rem;">Welcome Back</h1>
    
    <form asp-action="Login" method="post">
        <div class="form-group">
            <label asp-for="Email" class="form-label">Email Address</label>
            <input asp-for="Email" class="form-control" type="email" placeholder="your@email.com" required>
            <span asp-validation-for="Email" class="error-message"></span>
        </div>

        <div class="form-group">
            <label asp-for="Password" class="form-label">Password</label>
            <input asp-for="Password" class="form-control" type="password" placeholder="Enter your password" required>
            <span asp-validation-for="Password" class="error-message"></span>
        </div>

        <button type="submit" class="btn btn-primary-custom btn-block-custom">
            Sign In
        </button>
    </form>

    <div style="text-align: center; margin-top: 1.5rem;">
        <p>Don't have an account? <a href="/Auth/Register">Create one here</a></p>
        <p><a href="/">Back to Home</a></p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
