@page
@model EventBooking.Web.Pages.Events.IndexModel
@{
    ViewData["Title"] = "Events";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-0"><i class="bi bi-calendar3 me-2 text-primary"></i>Upcoming Events</h2>
        <p class="text-muted mb-0">Browse and book available events</p>
    </div>
    <div>
        <input type="text" id="searchInput" class="form-control" placeholder="&#xF52A; Search events..." style="min-width:220px;" />
    </div>
</div>

<div id="alertBox"></div>
<div id="loadingSpinner" class="text-center py-5">
    <div class="spinner-border text-primary" role="status"></div>
    <p class="mt-2 text-muted">Loading events…</p>
</div>

<div id="eventsGrid" class="row g-4" style="display:none!important;"></div>
<div id="noResults" class="text-center py-5 d-none">
    <i class="bi bi-calendar-x fs-1 text-muted"></i>
    <p class="mt-2 text-muted">No events found.</p>
</div>

<!-- Booking Modal -->
<div class="modal fade" id="bookingModal" tabindex="-1" aria-labelledby="bookingModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header bg-primary text-white">
        <h5 class="modal-title" id="bookingModalLabel"><i class="bi bi-ticket me-2"></i>Book Tickets</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div id="modalAlert"></div>
        <div class="mb-3">
            <label class="form-label fw-semibold">Event</label>
            <p id="modalEventTitle" class="text-muted mb-0"></p>
        </div>
        <div class="mb-3">
            <label class="form-label fw-semibold">Date &amp; Location</label>
            <p id="modalEventMeta" class="text-muted mb-0"></p>
        </div>
        <div class="mb-3">
            <label for="seatsInput" class="form-label fw-semibold">Seats to Book <span class="text-danger">*</span></label>
            <input type="number" id="seatsInput" class="form-control" min="1" max="100" value="1" />
            <div class="form-text">Available: <span id="modalAvailable" class="fw-bold text-success"></span></div>
            <div class="invalid-feedback" id="seatsError"></div>
        </div>
        <div class="mb-1">
            <label class="form-label fw-semibold">Price per Seat</label>
            <p id="modalPrice" class="text-muted mb-0"></p>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" id="confirmBookingBtn">
            <i class="bi bi-check-circle me-1"></i>Confirm Booking
        </button>
      </div>
    </div>
  </div>
</div>

@section Scripts {
<script src="~/js/events.js" asp-append-version="true"></script>
}
