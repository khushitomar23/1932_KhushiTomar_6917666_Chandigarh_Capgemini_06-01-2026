@page
@model EventBooking.Web.Pages.IndexModel
@{
    ViewData["Title"] = "Home";
}

<div class="hero-banner mb-5 text-center">
    <h1 class="display-5 fw-bold mb-2"><i class="bi bi-calendar-event me-2"></i>EventHub</h1>
    <p class="lead mb-4">Discover, book, and manage events — all in one place.</p>
    <a asp-page="/Events/Index" class="btn btn-light btn-lg px-4 me-2">
        <i class="bi bi-search me-1"></i>Browse Events
    </a>
    <a asp-page="/Bookings/MyBookings" class="btn btn-outline-light btn-lg px-4">
        <i class="bi bi-ticket-perforated me-1"></i>My Bookings
    </a>
</div>

<div class="row g-4 mb-5">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100 text-center p-4">
            <div class="fs-1 text-primary mb-3"><i class="bi bi-calendar-check"></i></div>
            <h5 class="fw-semibold">Browse Events</h5>
            <p class="text-muted small">Explore a wide range of upcoming events — conferences, concerts, workshops, and more.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100 text-center p-4">
            <div class="fs-1 text-success mb-3"><i class="bi bi-ticket-perforated"></i></div>
            <h5 class="fw-semibold">Book Instantly</h5>
            <p class="text-muted small">Reserve your seats in seconds. Get a booking confirmation right on screen.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100 text-center p-4">
            <div class="fs-1 text-warning mb-3"><i class="bi bi-shield-lock"></i></div>
            <h5 class="fw-semibold">Secure Access</h5>
            <p class="text-muted small">JWT-protected endpoints ensure only authenticated users can book or cancel tickets.</p>
        </div>
    </div>
</div>
