@model List<EmployeeProjectManagement.Models.Employee>

<h2>Employee List</h2>

<a asp-action="Create">Add Employee</a>

<table border="1" class="table">

    <thead>
        <tr>
            <th>Employee Id</th>
            <th>Name</th>
            <th>Department</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var emp in Model)
        {
            <tr>
                <td>@emp.EmployeeId</td>
                <td>@emp.Name</td>
                <td>@emp.Department?.Name</td>
            </tr>
        }
    </tbody>

</table>