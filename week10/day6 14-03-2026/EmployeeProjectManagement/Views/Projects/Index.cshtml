@model IEnumerable<EmployeeProjectManagement.Models.Project>

<h2>Projects</h2>

<table class="table">

    <tr>
        <th>Project Title</th>
        <th>Employees</th>
    </tr>

    @foreach (var project in Model)
    {
        <tr>

            <td>@project.Title</td>

            <td>
                @foreach (var ep in project.EmployeeProjects)
                {
                    <div>@ep.Employee.Name</div>
                }
            </td>

        </tr>
    }

</table>