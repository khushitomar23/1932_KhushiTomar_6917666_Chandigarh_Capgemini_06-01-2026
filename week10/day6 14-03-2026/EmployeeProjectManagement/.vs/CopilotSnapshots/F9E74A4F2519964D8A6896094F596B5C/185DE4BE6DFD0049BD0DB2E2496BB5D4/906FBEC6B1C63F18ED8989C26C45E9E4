@model IEnumerable<EmployeeProjectManagement.Models.Employee>

<h2>Employees List</h2>
<p>
    <a asp-action="Create" class="btn btn-primary">Add Employee</a>
</p>

<table class="table">
    <tr>
        <th>Employee Name</th>
        <th>Department</th>
    </tr>

    @foreach (var emp in Model)
    {
        <tr>
            <td>@emp.Name</td>
            <td>@emp.Department?.Name</td>
        </tr>
    }

</table>