@*
    Dashboard.cshtml
    ─────────────────────────────────────────────────────────────────────────
    Only reachable when Session contains "Username".
    If accessed without a session, AccountController.Dashboard() redirects
    back to Login before this view is ever rendered.

    ViewBag.Username → set by AccountController.Dashboard() from Session.
    ─────────────────────────────────────────────────────────────────────────
*@

@{
    ViewData["Title"] = "Dashboard";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dashboard</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: Arial, sans-serif;
            background-color: #f0f2f5;
            min-height: 100vh;
            padding: 30px;
            color: #222;
        }

        /* ── Top navbar ── */
        .navbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: #ffffff;
            border: 1px solid #dddddd;
            border-radius: 6px;
            padding: 12px 20px;
            margin-bottom: 24px;
        }

        .navbar .brand {
            font-size: 16px;
            font-weight: bold;
            color: #3366cc;
        }

        .navbar .user-info {
            font-size: 13px;
            color: #555;
        }

        .btn-logout {
            padding: 6px 14px;
            background-color: #cc3333;
            color: #fff;
            font-size: 13px;
            font-weight: bold;
            border: none;
            border-radius: 4px;
            text-decoration: none;
            cursor: pointer;
        }

        .btn-logout:hover { background-color: #aa2222; }

        /* ── Welcome card ── */
        .welcome-card {
            background: #ffffff;
            border: 1px solid #dddddd;
            border-radius: 6px;
            padding: 28px 24px;
            margin-bottom: 20px;
        }

        .welcome-card h2 {
            font-size: 22px;
            color: #222;
            margin-bottom: 6px;
        }

        .welcome-card p {
            font-size: 14px;
            color: #666;
        }

        .username-highlight {
            color: #3366cc;
            font-weight: bold;
        }

        /* ── Session info box ── */
        .session-box {
            background: #f0f5ff;
            border: 1px solid #c0d0f0;
            border-radius: 6px;
            padding: 16px 20px;
            font-size: 13px;
            color: #334499;
        }

        .session-box h4 {
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: #3366cc;
            margin-bottom: 10px;
        }

        .session-row {
            display: flex;
            gap: 10px;
            margin-bottom: 5px;
        }

        .session-row .key {
            font-weight: bold;
            min-width: 130px;
            color: #555;
        }

        .session-row .val {
            color: #222;
        }
    </style>
</head>
<body>

    @* ── Navbar ── *@
    <div class="navbar">
        <span class="brand">📊 MyApp Dashboard</span>
        <div style="display:flex; align-items:center; gap:16px;">
            <span class="user-info">
                Logged in as: <strong>@ViewBag.Username</strong>
            </span>
            @*
                Logout link calls AccountController.Logout()
                which runs HttpContext.Session.Clear() then redirects to Login.
            *@
            <a href="@Url.Action("Logout", "Account")" class="btn-logout">Logout</a>
        </div>
    </div>

    @* ── Welcome card ── *@
    <div class="welcome-card">
        <h2>👋 Welcome, <span class="username-highlight">@ViewBag.Username</span>!</h2>
        <p>You are successfully logged in. Your session is active.</p>
    </div>

    @* ── Session info (educational — shows what is stored in session) ── *@
    <div class="session-box">
        <h4>🔍 Session Details (for learning purposes)</h4>

        <div class="session-row">
            <span class="key">Session Key:</span>
            <span class="val">"Username"</span>
        </div>

        <div class="session-row">
            <span class="key">Session Value:</span>
            <span class="val">@ViewBag.Username</span>
        </div>

        <div class="session-row">
            <span class="key">How it's stored:</span>
            <span class="val">Server-side (in memory). Browser only holds a Session ID cookie.</span>
        </div>

        <div class="session-row">
            <span class="key">How to log out:</span>
            <span class="val">HttpContext.Session.Clear() — removes all session data.</span>
        </div>

        <div class="session-row">
            <span class="key">Guard check:</span>
            <span class="val">Dashboard action reads Session — redirects to Login if null.</span>
        </div>
    </div>

</body>
</html>
