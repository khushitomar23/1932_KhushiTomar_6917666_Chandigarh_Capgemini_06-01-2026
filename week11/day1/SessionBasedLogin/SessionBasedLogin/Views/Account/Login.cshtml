@*
    Login.cshtml
    ─────────────────────────────────────────────────────────────────────────
    Plain form with two fields: username and password.
    On POST, AccountController.Login() validates and writes to Session.

    Things to note:
      • method="post"              → HTTP POST to AccountController.Login
      • @Html.AntiForgeryToken()   → CSRF protection token
      • ViewBag.ErrorMessage       → set by controller on invalid credentials
      • TempData["InfoMessage"]    → set by Logout / Dashboard redirect guard
    ─────────────────────────────────────────────────────────────────────────
*@

@{
    ViewData["Title"] = "Login";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: Arial, sans-serif;
            background-color: #f0f2f5;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
        }

        .login-box {
            background: #ffffff;
            border: 1px solid #dddddd;
            border-radius: 6px;
            padding: 32px 30px;
            width: 100%;
            max-width: 380px;
        }

        .login-box h2 {
            font-size: 20px;
            color: #222;
            margin-bottom: 4px;
        }

        .login-box .subtitle {
            font-size: 13px;
            color: #888;
            margin-bottom: 22px;
        }

        hr {
            border: none;
            border-top: 1px solid #eeeeee;
            margin-bottom: 20px;
        }

        /* ── Alerts ── */
        .alert {
            padding: 9px 12px;
            border-radius: 4px;
            font-size: 13px;
            margin-bottom: 16px;
        }

        .alert-error {
            background-color: #fff0f0;
            border: 1px solid #f5c0c0;
            color: #cc0000;
        }

        .alert-info {
            background-color: #fffbe6;
            border: 1px solid #ffe58f;
            color: #7a5700;
        }

        /* ── Fields ── */
        .field {
            margin-bottom: 14px;
        }

        label {
            display: block;
            font-size: 12px;
            font-weight: bold;
            color: #555;
            margin-bottom: 5px;
            text-transform: uppercase;
            letter-spacing: 0.04em;
        }

        input[type="text"],
        input[type="password"] {
            width: 100%;
            padding: 8px 10px;
            font-size: 14px;
            border: 1px solid #cccccc;
            border-radius: 4px;
            outline: none;
            color: #222;
        }

        input:focus {
            border-color: #3366cc;
        }

        /* ── Button ── */
        .btn-login {
            width: 100%;
            padding: 9px;
            margin-top: 6px;
            background-color: #3366cc;
            color: #ffffff;
            font-size: 14px;
            font-weight: bold;
            border: none;
            border-radius: 4px;
            cursor: pointer;
        }

        .btn-login:hover {
            background-color: #2255bb;
        }

        /* ── Hint ── */
        .hint {
            margin-top: 14px;
            font-size: 12px;
            color: #aaa;
            text-align: center;
        }
    </style>
</head>
<body>

<div class="login-box">
    <h2>🔐 Login</h2>
    <p class="subtitle">Enter your credentials to continue.</p>
    <hr />

    @*
        TempData["InfoMessage"] is set by:
          - Logout action  → "You have been logged out."
          - Dashboard guard → "Please log in to access the dashboard."
        TempData survives exactly one redirect, then clears automatically.
    *@
    @if (TempData["InfoMessage"] != null)
    {
        <div class="alert alert-info">ℹ️ @TempData["InfoMessage"]</div>
    }

    @*
        ViewBag.ErrorMessage is set by the POST Login action
        when username/password don't match.
    *@
    @if (ViewBag.ErrorMessage != null)
    {
        <div class="alert alert-error">❌ @ViewBag.ErrorMessage</div>
    }

    @*
        asp-action="Login"       → POST to AccountController.Login
        asp-controller="Account" → targets AccountController
        The form fields are named "username" and "password" which match the
        parameter names in Login(string username, string password) — this is
        how Model Binding maps form values to action parameters.
    *@
    <form asp-action="Login" asp-controller="Account" method="post">
        @Html.AntiForgeryToken()

        <div class="field">
            <label for="username">Username</label>
            <input type="text" id="username" name="username"
                   placeholder="Enter username" autocomplete="username" />
        </div>

        <div class="field">
            <label for="password">Password</label>
            <input type="password" id="password" name="password"
                   placeholder="Enter password" autocomplete="current-password" />
        </div>

        <button type="submit" class="btn-login">Login →</button>
    </form>

    <p class="hint">Hint: admin / 123</p>
</div>

</body>
</html>
