@{ ViewData["Title"] = "Admin Dashboard"; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" /><meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Dashboard — Employee Portal</title>
    <style>
        *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
        body{font-family:Arial,sans-serif;background:#f0f2f5;padding:24px;color:#222}
        .alert-success{background:#f0fff4;border:1px solid #9ae6b4;color:#276749;padding:10px 14px;border-radius:4px;font-size:13px;margin-bottom:20px;font-weight:bold}
        .welcome-card{background:#1e3a5f;border-radius:6px;padding:28px 24px;margin-bottom:20px;color:#fff}
        .welcome-card h2{font-size:22px;margin-bottom:6px}
        .welcome-card p{font-size:14px;color:rgba(255,255,255,.75)}
        .cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px;margin-bottom:20px}
        .card{background:#fff;border:1px solid #ddd;border-radius:6px;padding:20px;text-align:center}
        .card .icon{font-size:28px;margin-bottom:8px}
        .card .label{font-size:12px;color:#888;text-transform:uppercase;letter-spacing:.05em;margin-bottom:4px}
        .card .value{font-size:22px;font-weight:bold;color:#1e3a5f}
        .session-box{background:#fff;border:1px solid #ddd;border-radius:6px;padding:20px}
        .session-box h4{font-size:13px;text-transform:uppercase;letter-spacing:.05em;color:#1e3a5f;margin-bottom:12px}
        .s-row{display:flex;gap:10px;margin-bottom:6px;font-size:13px}
        .s-key{font-weight:bold;min-width:150px;color:#555}
        .s-val{color:#222}
        .btn{display:inline-block;padding:8px 16px;border-radius:4px;font-size:13px;font-weight:bold;text-decoration:none}
        .btn-primary{background:#1e3a5f;color:#fff}
        .btn-primary:hover{background:#16304f}
    </style>
</head>
<body>
@Html.Partial("_Navbar")

@if (TempData["SuccessMessage"] != null) {
    <div class="alert-success">✅ @TempData["SuccessMessage"]</div>
}

<div class="welcome-card">
    <h2>👋 Welcome, @ViewBag.Username!</h2>
    <p>You are logged in as <strong>@ViewBag.Role</strong>. Your session is active (30 min idle timeout).</p>
</div>

<div class="cards">
    <div class="card">
        <div class="icon">👥</div>
        <div class="label">Manage Employees</div>
        <div class="value" style="font-size:14px;margin-top:6px">
            <a href="@Url.Action("Index","Employee")" class="btn btn-primary">View All</a>
        </div>
    </div>
    <div class="card">
        <div class="icon">📊</div>
        <div class="label">HR Module</div>
        <div class="value" style="font-size:14px;margin-top:6px">
            <a href="@Url.Action("Index","HR")" class="btn btn-primary">Open HR</a>
        </div>
    </div>
    <div class="card">
        <div class="icon">📈</div>
        <div class="label">Reports</div>
        <div class="value" style="font-size:14px;margin-top:6px">
            <a href="@Url.Action("Reports","HR")" class="btn btn-primary">View Reports</a>
        </div>
    </div>
</div>

<div class="session-box">
    <h4>🔍 Active Session Details</h4>
    <div class="s-row"><span class="s-key">Session Key "Username":</span><span class="s-val">@ViewBag.Username</span></div>
    <div class="s-row"><span class="s-key">Session Key "Role":</span><span class="s-val">@ViewBag.Role</span></div>
    <div class="s-row"><span class="s-key">Idle Timeout:</span><span class="s-val">30 minutes</span></div>
    <div class="s-row"><span class="s-key">Storage:</span><span class="s-val">Server-side (in-memory). Browser holds only the Session ID cookie.</span></div>
</div>
</body></html>
