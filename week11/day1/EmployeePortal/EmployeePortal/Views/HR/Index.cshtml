@{ ViewData["Title"] = "HR Dashboard"; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" /><meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>HR Dashboard — Portal</title>
    <style>
        *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
        body{font-family:Arial,sans-serif;background:#f0f2f5;padding:24px;color:#222}
        .page-header{margin-bottom:20px}
        .page-header h2{font-size:20px;color:#222;margin-bottom:3px}
        .page-header p{font-size:13px;color:#888}
        .cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:16px;margin-bottom:24px}
        .card{background:#fff;border:1px solid #ddd;border-radius:6px;padding:20px;text-align:center}
        .card .icon{font-size:30px;margin-bottom:8px}
        .card .label{font-size:11px;color:#888;text-transform:uppercase;letter-spacing:.05em;margin-bottom:4px}
        .card .value{font-size:28px;font-weight:bold;color:#1e3a5f}
        .modules{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px}
        .module-card{background:#fff;border:1px solid #ddd;border-radius:6px;padding:20px}
        .module-card h4{font-size:15px;color:#1e3a5f;margin-bottom:6px}
        .module-card p{font-size:13px;color:#666;margin-bottom:14px}
        .btn{display:inline-block;padding:7px 14px;font-size:13px;font-weight:bold;border-radius:4px;text-decoration:none}
        .btn-primary{background:#1e3a5f;color:#fff}
        .btn-danger{background:#cc3333;color:#fff}
        .btn-primary:hover{background:#16304f}
        .btn-danger:hover{background:#aa2222}
        .info-box{background:#fffbe6;border:1px solid #ffe58f;border-radius:4px;padding:10px 14px;font-size:13px;color:#7a5700;margin-bottom:20px}
    </style>
</head>
<body>
@Html.Partial("_Navbar")

<div class="page-header">
    <h2>📊 HR Dashboard</h2>
    <p>Overview of company workforce. LogActionFilter is active — check your console.</p>
</div>

<div class="info-box">
    ℹ️ <strong>LogActionFilter</strong> logged this request (Controller, Action, User, Timestamp) to the console.
</div>

<div class="cards">
    <div class="card">
        <div class="icon">👥</div>
        <div class="label">Total Employees</div>
        <div class="value">@ViewBag.TotalEmployees</div>
    </div>
    <div class="card">
        <div class="icon">🏢</div>
        <div class="label">Departments</div>
        <div class="value">@ViewBag.Departments</div>
    </div>
    <div class="card">
        <div class="icon">🆕</div>
        <div class="label">Joined This Month</div>
        <div class="value">@ViewBag.NewThisMonth</div>
    </div>
</div>

<div class="modules">
    <div class="module-card">
        <h4>📋 Employee List</h4>
        <p>View and filter the full employee directory by department.</p>
        <a href="@Url.Action("EmployeeList","HR")" class="btn btn-primary">Open →</a>
    </div>
    <div class="module-card">
        <h4>📈 Department Reports</h4>
        <p>View department-wise headcount, average age and latest joinees.</p>
        <a href="@Url.Action("Reports","HR")" class="btn btn-primary">Open →</a>
    </div>
    <div class="module-card">
        <h4>💥 Test Exception Filter</h4>
        <p>Trigger an unhandled exception to see CustomExceptionFilter in action.</p>
        <a href="@Url.Action("SimulateReportsError","HR")" class="btn btn-danger">Simulate Error →</a>
    </div>
</div>
</body></html>
