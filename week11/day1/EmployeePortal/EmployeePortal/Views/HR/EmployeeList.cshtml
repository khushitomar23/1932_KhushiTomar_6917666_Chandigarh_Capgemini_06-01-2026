@model List<EmployeePortal.Models.Employee>
@{ ViewData["Title"] = "Employee List"; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" /><meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Employee List — HR Portal</title>
    <style>
        *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
        body{font-family:Arial,sans-serif;background:#f0f2f5;padding:24px;color:#222}
        .page-header{margin-bottom:16px}
        .page-header h2{font-size:20px;color:#222;margin-bottom:3px}
        .page-header p{font-size:13px;color:#888}
        /* Filter bar */
        .filter-bar{background:#fff;border:1px solid #ddd;border-radius:6px;padding:14px 18px;margin-bottom:16px;display:flex;align-items:center;gap:12px;flex-wrap:wrap}
        .filter-bar label{font-size:12px;font-weight:bold;color:#555;text-transform:uppercase;letter-spacing:.04em}
        .filter-bar select{padding:6px 10px;font-size:13px;border:1px solid #ccc;border-radius:4px;outline:none;color:#222;background:#fff}
        .filter-bar select:focus{border-color:#1e3a5f}
        .btn{padding:7px 14px;font-size:13px;font-weight:bold;border:none;border-radius:4px;cursor:pointer;text-decoration:none;display:inline-block}
        .btn-primary{background:#1e3a5f;color:#fff}
        .btn-outline{background:#fff;color:#1e3a5f;border:1px solid #1e3a5f}
        .btn-primary:hover{background:#16304f}
        .btn-outline:hover{background:#e8f0fb}
        /* Table */
        .table-wrap{background:#fff;border:1px solid #ddd;border-radius:6px;overflow:hidden}
        table{width:100%;border-collapse:collapse;font-size:14px}
        thead{background:#1e3a5f;color:#fff}
        thead th{padding:10px 14px;text-align:left;font-size:12px;text-transform:uppercase;letter-spacing:.04em}
        tbody tr:nth-child(even){background:#f9f9f9}
        tbody tr:hover{background:#eef3ff}
        tbody td{padding:10px 14px;border-bottom:1px solid #eee;color:#333}
        tbody tr:last-child td{border-bottom:none}
        .dept-tag{background:#e8f4fd;color:#1e3a5f;padding:2px 8px;border-radius:8px;font-size:12px;font-weight:bold}
        .id-badge{background:#1e3a5f;color:#fff;padding:1px 8px;border-radius:8px;font-size:12px}
        .link{color:#1e3a5f;font-weight:bold;text-decoration:none}
        .link:hover{text-decoration:underline}
        .empty{text-align:center;padding:30px;color:#aaa;font-size:14px}
        .result-count{font-size:13px;color:#555;margin-bottom:10px}
    </style>
</head>
<body>
@Html.Partial("_Navbar")

<div class="page-header">
    <h2>📋 Employee List</h2>
    <p>Full company directory. Filter by department below.</p>
</div>

@*
    Department filter — submits as GET so the URL reflects the filter,
    making it shareable/bookmarkable: /HR/EmployeeList?department=Engineering
*@
<div class="filter-bar">
    <label for="deptFilter">Filter by Department:</label>
    <form method="get" asp-action="EmployeeList" asp-controller="HR" style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
        <select name="department" id="deptFilter" onchange="this.form.submit()">
            <option value="">-- All Departments --</option>
            @foreach (var dept in (IEnumerable<string>)ViewBag.Departments)
            {
                if (dept == (string?)ViewBag.Selected)
                {
                    <option value="@dept" selected>@dept</option>
                }
                else
                {
                    <option value="@dept">@dept</option>
                }
            }
        </select>
        @if (ViewBag.Selected != null)
        {
            <a href="@Url.Action("EmployeeList","HR")" class="btn btn-outline">✕ Clear Filter</a>
        }
    </form>
</div>

<p class="result-count">
    Showing <strong>@Model.Count</strong> employee(s)
    @if (ViewBag.Selected != null) { <text>in <strong>@ViewBag.Selected</strong></text> }
</p>

<div class="table-wrap">
    @if (!Model.Any())
    {
        <p class="empty">No employees found for the selected filter.</p>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Age</th>
                    <th>Email</th>
                    <th>Department</th>
                    <th>Joined</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var e in Model)
                {
                    <tr>
                        <td><span class="id-badge">#@e.Id</span></td>
                        <td>@e.Name</td>
                        <td>@e.Age</td>
                        <td>@e.Email</td>
                        <td><span class="dept-tag">@e.Department</span></td>
                        <td>@e.JoinedOn.ToString("dd MMM yyyy")</td>
                        <td>
                            <a href="@Url.Action("Details","Employee",new{id=e.Id})" class="link">View</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

</body>
</html>
