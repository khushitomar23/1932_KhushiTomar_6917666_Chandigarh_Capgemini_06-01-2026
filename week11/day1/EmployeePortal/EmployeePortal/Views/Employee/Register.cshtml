@model EmployeePortal.Models.Employee
@{ ViewData["Title"] = "Register Employee"; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" /><meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Register Employee — Portal</title>
    <style>
        *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
        body{font-family:Arial,sans-serif;background:#f0f2f5;padding:24px;color:#222}
        .form-wrap{background:#fff;border:1px solid #ddd;border-radius:6px;padding:28px;max-width:500px;margin:0 auto}
        h2{font-size:18px;color:#222;margin-bottom:4px}
        .sub{font-size:13px;color:#888;margin-bottom:18px}
        hr{border:none;border-top:1px solid #eee;margin-bottom:18px}
        .field{margin-bottom:14px}
        label{display:block;font-size:12px;font-weight:bold;color:#555;text-transform:uppercase;letter-spacing:.04em;margin-bottom:5px}
        input[type=text],input[type=number],input[type=email],select{width:100%;padding:8px 10px;font-size:14px;border:1px solid #ccc;border-radius:4px;outline:none;color:#222;background:#fff}
        input:focus,select:focus{border-color:#1e3a5f}
        input.input-validation-error,select.input-validation-error{border-color:#cc0000;background:#fff8f8}
        .field-error{color:#cc0000;font-size:12px;margin-top:4px;display:block}
        .btn{width:100%;padding:9px;background:#1e3a5f;color:#fff;font-size:14px;font-weight:bold;border:none;border-radius:4px;cursor:pointer;margin-top:4px}
        .btn:hover{background:#16304f}
        .back{display:inline-block;font-size:13px;color:#1e3a5f;text-decoration:none;margin-top:12px}
        .back:hover{text-decoration:underline}
        .note{font-size:12px;color:#aaa;text-align:center;margin-top:10px}
    </style>
</head>
<body>
@Html.Partial("_Navbar")

<div class="form-wrap">
    <h2>📝 Register Employee</h2>
    <p class="sub">Fill in all details to register a new employee.</p>
    <hr />

    <form asp-action="Register" asp-controller="Employee" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="field-error" style="margin-bottom:12px"></div>

        <div class="field">
            <label asp-for="Name">Full Name</label>
            <input asp-for="Name" type="text" placeholder="e.g. Priya Sharma" />
            <span asp-validation-for="Name" class="field-error"></span>
        </div>

        <div class="field">
            <label asp-for="Age">Age</label>
            <input asp-for="Age" type="number" placeholder="Between 21 and 65" min="21" max="65" />
            <span asp-validation-for="Age" class="field-error"></span>
        </div>

        <div class="field">
            <label asp-for="Email">Email Address</label>
            <input asp-for="Email" type="email" placeholder="e.g. priya@company.com" />
            <span asp-validation-for="Email" class="field-error"></span>
        </div>

        <div class="field">
            <label asp-for="Department">Department</label>
            <select asp-for="Department">
                <option value="">-- Select Department --</option>
                <option>Engineering</option>
                <option>HR</option>
                <option>Finance</option>
                <option>Operations</option>
                <option>Marketing</option>
                <option>Legal</option>
                <option>IT</option>
            </select>
            <span asp-validation-for="Department" class="field-error"></span>
        </div>

        <button type="submit" class="btn">Register Employee →</button>
    </form>

    <a href="@Url.Action("Index","Employee")" class="back">← Back to Employee List</a>
    <p class="note">All fields are required.</p>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>
</body></html>
