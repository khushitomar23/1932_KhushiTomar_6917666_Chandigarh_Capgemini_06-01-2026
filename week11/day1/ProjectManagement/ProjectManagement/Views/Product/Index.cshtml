@model List<ProductManagement.Models.Product>
@{
    ViewData["Title"] = "Product Management";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: Arial, sans-serif;
            background-color: #f5f5f5;
            padding: 30px;
            color: #222;
        }

        .page-header {
            margin-bottom: 20px;
        }

        .page-header h2 {
            font-size: 22px;
            color: #222;
            margin-bottom: 4px;
        }

        .page-header p {
            font-size: 13px;
            color: #888;
        }

        /* ── Toolbar ── */
        .toolbar {
            display: flex;
            gap: 10px;
            margin-bottom: 16px;
        }

        .btn {
            padding: 7px 16px;
            font-size: 13px;
            font-weight: bold;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            text-decoration: none;
            display: inline-block;
        }

        .btn-primary { background-color: #3366cc; color: #fff; }
        .btn-danger  { background-color: #cc3333; color: #fff; }
        .btn-primary:hover { background-color: #2255bb; }
        .btn-danger:hover  { background-color: #aa2222; }

        /* ── Table ── */
        .table-wrap {
            background: #fff;
            border: 1px solid #ddd;
            border-radius: 6px;
            overflow: hidden;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 14px;
        }

        thead {
            background-color: #3366cc;
            color: #fff;
        }

        thead th {
            padding: 11px 14px;
            text-align: left;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 0.04em;
        }

        tbody tr:nth-child(even) { background-color: #f9f9f9; }
        tbody tr:hover           { background-color: #eef3ff; }

        tbody td {
            padding: 10px 14px;
            border-bottom: 1px solid #eeeeee;
            color: #333;
        }

        tbody tr:last-child td { border-bottom: none; }

        /* Stock badge */
        .badge {
            display: inline-block;
            padding: 2px 8px;
            border-radius: 10px;
            font-size: 12px;
            font-weight: bold;
        }
        .badge-ok  { background-color: #e6f4ea; color: #2a6a2a; }
        .badge-low { background-color: #fff4e5; color: #a05000; }

        /* ── Filter notice ── */
        .filter-notice {
            background-color: #eef3ff;
            border: 1px solid #c0d0f0;
            border-radius: 4px;
            padding: 10px 14px;
            font-size: 13px;
            color: #334499;
            margin-bottom: 16px;
        }
    </style>
</head>
<body>

    <div class="page-header">
        <h2>📦 Product Management</h2>
        <p>All registered products are listed below.</p>
    </div>

    <!-- Reminder that filters are active -->
    <div class="filter-notice">
        ℹ️ <strong>LogActionFilter</strong> is active — check your console for log output.<br />
        To test the <strong>CustomExceptionFilter</strong>, click the button below.
    </div>

    <!-- Toolbar -->
    <div class="toolbar">
        <a href="@Url.Action("Index", "Product")" class="btn btn-primary">🔄 Refresh</a>
        @*
            SimulateError deliberately throws an exception.
            CustomExceptionFilter (registered globally) will catch it
            and render the friendly Error view instead of crashing.
        *@
        <a href="@Url.Action("SimulateError", "Product")" class="btn btn-danger">💥 Simulate Exception</a>
    </div>

    <!-- Product table -->
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>#</th>
                    <th>Product Name</th>
                    <th>Category</th>
                    <th>Price (₹)</th>
                    <th>Stock</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td>@p.Id</td>
                        <td>@p.Name</td>
                        <td>@p.Category</td>
                        <td>₹@p.Price.ToString("N2")</td>
                        <td>
                            @if (p.Stock > 30)
                            {
                                <span class="badge badge-ok">@p.Stock units</span>
                            }
                            else
                            {
                                <span class="badge badge-low">@p.Stock units (Low)</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</body>
</html>
