:root{
  --v1: #ff5f6d;
  --v2: #ffc371;
  --v3: #24c6dc;
  --v4: #514a9d;
  --glass-bg: rgba(255,255,255,0.06);
  --glass-border: rgba(255,255,255,0.12);
  --glass-shadow: 0 8px 30px rgba(0,0,0,0.35);
}

/* Page background: animated vibrant gradient */
html, body {
  height: 100%;
  margin: 0;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial;
  background: linear-gradient(120deg, var(--v1), var(--v2), var(--v3), var(--v4));
  background-size: 600% 600%;
  animation: gradientShift 18s ease infinite;
  color: #fff;
  -webkit-font-smoothing:antialiased;
  -moz-osx-font-smoothing:grayscale;
}

@keyframes gradientShift {
  0% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

/* A reusable 'vibrant window' glass panel */
.vibrant-window {
  max-width: 1100px;
  margin: 36px auto;
  padding: 28px;
  border-radius: 16px;
  background: linear-gradient(180deg, rgba(255,255,255,0.06), rgba(255,255,255,0.03));
  border: 1px solid var(--glass-border);
  box-shadow: var(--glass-shadow);
  backdrop-filter: blur(8px) saturate(140%);
  -webkit-backdrop-filter: blur(8px) saturate(140%);
  transition: transform 240ms ease, box-shadow 240ms ease;
}

/* Lift effect on hover (for desktop) */
.vibrant-window:hover {
  transform: translateY(-6px);
  box-shadow: 0 20px 50px rgba(0,0,0,0.45);
}

/* Page header / title */
.vibrant-window .page-title {
  margin: 0 0 14px 0;
  font-size: 1.6rem;
  letter-spacing: -0.02em;
  text-shadow: 0 1px 0 rgba(0,0,0,0.25);
}

/* Accent separators and subtle glowing outlines */
.vibrant-accent {
  height: 4px;
  width: 64px;
  border-radius: 999px;
  margin: 12px 0 20px;
  background: linear-gradient(90deg, rgba(255,255,255,0.18), rgba(255,255,255,0.02));
  box-shadow: 0 6px 18px rgba(0,0,0,0.18), 0 0 24px rgba(255,255,255,0.04) inset;
}

/* Buttons with neon-like outlines */
.btn-vibrant {
  display: inline-block;
  padding: 10px 16px;
  border-radius: 10px;
  background: linear-gradient(180deg, rgba(255,255,255,0.12), rgba(255,255,255,0.06));
  border: 1px solid rgba(255,255,255,0.12);
  color: #fff;
  text-decoration: none;
  box-shadow: 0 6px 18px rgba(0,0,0,0.25), 0 0 12px rgba(255,255,255,0.03) inset;
  transition: transform 160ms ease, box-shadow 160ms ease;
}
.btn-vibrant:focus,
.btn-vibrant:hover {
  transform: translateY(-3px);
  box-shadow: 0 22px 40px rgba(0,0,0,0.4), 0 0 36px rgba(255,255,255,0.06) inset;
}

/* Links */
a {
  color: #fff;
  text-decoration: underline;
  text-decoration-color: rgba(255,255,255,0.18);
}
a:hover { text-decoration-color: rgba(255,255,255,0.35); }

/* Form elements subtly themed */
input, select, textarea {
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.08);
  color: #fff;
  padding: 8px 10px;
  border-radius: 8px;
  outline: none;
}
input:focus, select:focus, textarea:focus {
  border-color: rgba(255,255,255,0.18);
  box-shadow: 0 6px 20px rgba(0,0,0,0.4), 0 0 12px rgba(255,255,255,0.03) inset;
}

