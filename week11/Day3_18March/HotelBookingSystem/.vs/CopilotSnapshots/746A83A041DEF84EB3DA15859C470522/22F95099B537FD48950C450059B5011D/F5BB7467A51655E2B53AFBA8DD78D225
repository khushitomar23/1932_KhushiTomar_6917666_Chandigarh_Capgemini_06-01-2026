using Microsoft.AspNetCore.Mvc;
using HotelBookingSystem.Models;
using System.Linq;

namespace HotelBookingSystem.Controllers
{
    public class BookingsController : Controller
    {
        private readonly HotelContext _context;

        public BookingsController(HotelContext context)
        {
            _context = context;
        }

        public IActionResult Index()
        {
            return View(_context.Bookings.ToList());
        }

        public IActionResult Create()
        {
            ViewBag.Rooms = _context.Rooms.ToList();
            ViewBag.Customers = _context.Customers.ToList();
            return View();
        }

        [HttpPost]
        public IActionResult Create(Booking booking)
        {
            if (IsRoomAvailable(booking.RoomId, booking.CheckInDate, booking.CheckOutDate))
            {
                _context.Bookings.Add(booking);
                _context.SaveChanges();
                TempData["Success"] = "Booking Confirmed!";
            }
            else
            {
                TempData["Error"] = "Room not available!";
            }

            return RedirectToAction("Index");
        }

        private bool IsRoomAvailable(int roomId, DateTime checkIn, DateTime checkOut)
        {
            return !_context.Bookings.Any(b =>
                b.RoomId == roomId &&
                checkIn < b.CheckOutDate &&
                checkOut > b.CheckInDate);
        }
    }
}
