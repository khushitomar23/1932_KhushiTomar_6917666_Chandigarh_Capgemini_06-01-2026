@model IEnumerable<ECommerceOMS.Models.Category>
@{
    ViewData["Title"] = "Categories";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Categories</h2>
    <a asp-action="Create" class="btn btn-success">+ Add Category</a>
</div>

<table class="table table-bordered shadow-sm">
    <thead class="table-dark"><tr><th>Name</th><th>Description</th><th>Products</th><th>Actions</th></tr></thead>
    <tbody>
        @foreach (var c in Model)
        {
            <tr>
                <td>@c.Name</td>
                <td>@c.Description</td>
                <td><span class="badge bg-primary">@c.Products.Count</span></td>
                <td>
                    <a asp-action="Edit" asp-route-id="@c.CategoryId" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@c.CategoryId" class="btn btn-sm btn-danger"
                       onclick="return confirm('Delete?')">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>