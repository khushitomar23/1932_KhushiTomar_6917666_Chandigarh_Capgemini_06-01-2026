@model IEnumerable<ECommerceOMS.Models.Customer>
@{
    ViewData["Title"] = "Customers";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Customers</h2>
    <a asp-action="Create" class="btn btn-success">+ Add Customer</a>
</div>

<table class="table table-hover table-bordered shadow-sm">
    <thead class="table-dark">
        <tr><th>Name</th><th>Email</th><th>Phone</th><th>Address</th><th>Actions</th></tr>
    </thead>
    <tbody>
        @foreach (var c in Model)
        {
            <tr>
                <td>@c.FullName</td>
                <td>@c.Email</td>
                <td>@c.Phone</td>
                <td>@c.Address</td>
                <td>
                    <a asp-action="Details" asp-route-id="@c.CustomerId" class="btn btn-sm btn-info">History</a>
                    <a asp-action="Edit" asp-route-id="@c.CustomerId" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@c.CustomerId" class="btn btn-sm btn-danger"
                       onclick="return confirm('Delete?')">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>