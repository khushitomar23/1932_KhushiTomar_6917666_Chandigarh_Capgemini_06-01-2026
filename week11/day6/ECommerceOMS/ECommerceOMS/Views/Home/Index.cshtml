@{
    ViewData["Title"] = "Home";
}


<div class="container-fluid p-5" style="background-color:#ffc0cb;">
    <h1 class="text-center">Welcome to My Store</h1>
</div>


<div class="text-center py-5">
    <h1 class="display-4">E-Commerce Order Management</h1>
    <p class="lead text-muted">Manage products, customers, orders and shipments from one place.</p>
    <hr />
    <div class="d-flex justify-content-center gap-3 flex-wrap mt-4">
        <a asp-controller="Products" asp-action="Index" class="btn btn-primary btn-lg">Browse Products</a>
        <a asp-controller="Customers" asp-action="Index" class="btn btn-success btn-lg">View Customers</a>
        <a asp-controller="Orders" asp-action="Index" class="btn btn-warning btn-lg">All Orders</a>
        <a asp-controller="Admin" asp-action="Dashboard" class="btn btn-dark btn-lg">Admin Dashboard</a>
    </div>
</div>