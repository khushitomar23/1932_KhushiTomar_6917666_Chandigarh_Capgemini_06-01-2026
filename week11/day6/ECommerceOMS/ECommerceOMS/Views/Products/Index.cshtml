@model IEnumerable<ECommerceOMS.Models.Product>
@{
    ViewData["Title"] = "Products";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Products</h2>
    <a asp-action="Create" class="btn btn-success">+ Add Product</a>
</div>

<!-- Category Filter -->
<div class="mb-3">
    @foreach (var cat in (List<ECommerceOMS.Models.Category>)ViewBag.Categories)
    {
        var active = (int?)ViewBag.SelectedCategory == cat.CategoryId ? "btn-primary" : "btn-outline-primary";
        <a asp-action="Index" asp-route-categoryId="@cat.CategoryId" class="btn btn-sm @active me-1">@cat.Name</a>
    }
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">All</a>
</div>

<div class="row row-cols-1 row-cols-md-3 g-4">
    @foreach (var p in Model)
    {
        <div class="col">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <span class="badge bg-secondary mb-1">@p.Category?.Name</span>
                    <h5 class="card-title">@p.Name</h5>
                    <p class="card-text text-muted small">@p.Description</p>
                    <p class="fw-bold text-success fs-5">₹@p.Price</p>
                    <p class="text-muted small">Stock: @p.Stock</p>
                </div>
                <div class="card-footer d-flex gap-2">
                    <a asp-action="Details" asp-route-id="@p.ProductId" class="btn btn-sm btn-info">Details</a>
                    <a asp-action="Edit" asp-route-id="@p.ProductId" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@p.ProductId" class="btn btn-sm btn-danger"
                       onclick="return confirm('Delete this product?')">Delete</a>
                </div>
            </div>
        </div>
    }
</div>